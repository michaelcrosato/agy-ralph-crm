NODE_ENV=development
PORT=3001

# Optional API URL overrides for local debugging and integration runs.
# API_BASE_URL=http://localhost:3001

# OpenTelemetry — leave OTEL_DISABLED=1 to skip OTel entirely in dev.
# OTEL_DISABLED=1
OTEL_SERVICE_NAME=crm-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Database configuration (DB_DRIVER=mock|pg)
DB_DRIVER=mock
DB_URL=postgres://postgres:postgres@localhost:5432/crm
