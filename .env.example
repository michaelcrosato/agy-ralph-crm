NODE_ENV=development
PORT=3001

# Session signing. Leave blank in committed templates; production must set a
# unique 32+ character secret.
JWT_SECRET=

# Optional API URL overrides for local debugging and integration runs.
# API_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3001

# OpenTelemetry — leave OTEL_DISABLED=1 to skip OTel entirely in dev.
# OTEL_DISABLED=1
OTEL_SERVICE_NAME=crm-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Database configuration (DB_DRIVER=mock|pg)
DB_DRIVER=mock
DB_URL=postgres://postgres:postgres@localhost:5432/crm

# AI/search providers default to deterministic mocks. Do not set live provider
# keys during unattended agent loops.
EMBEDDINGS_PROVIDER=mock
# OPENAI_API_KEY=
RERANK_PROVIDER=mock
# COHERE_API_KEY=

# API Security and Hardening settings (spec 052)
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# RATE_LIMIT_PER_MIN=100
