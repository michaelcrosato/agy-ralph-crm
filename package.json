{
  "name": "crm-core-monorepo",
  "private": true,
  "engines": {
    "node": ">=22.22.3 <23",
    "pnpm": ">=11.1.2 <12"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "verify": "turbo run verify",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "node scripts/agent/agent-runner.mjs test-e2e",
    "test:e2e:playwright": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "dev": "turbo run dev",
    "agent:bootstrap": "node scripts/agent/agent-runner.mjs bootstrap",
    "agent:doctor": "node scripts/agent/agent-runner.mjs doctor",
    "agent:check": "node scripts/agent/agent-runner.mjs check",
    "agent:test": "node scripts/agent/agent-runner.mjs test",
    "agent:test:e2e": "node scripts/agent/agent-runner.mjs test-e2e",
    "agent:lint": "node scripts/agent/agent-runner.mjs lint",
    "agent:typecheck": "node scripts/agent/agent-runner.mjs typecheck",
    "agent:format": "node scripts/agent/agent-runner.mjs format",
    "agent:status": "node scripts/agent/agent-runner.mjs status",
    "agent:rotate-logs": "node scripts/agent/rotate-logs.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "@biomejs/biome": "^2.4.0",
    "@playwright/test": "^1.49.0",
    "postgres": "^3.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "ssh2"
